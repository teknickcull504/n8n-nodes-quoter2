{
	"name": "n8n-nodes-quoter",
	"version": "0.1.0",
	"description": "n8n community node for the Quoter quoting software API",
	"keywords": [
		"n8n-community-node-package",
		"quoter",
		"quoting",
		"quotes",
		"sales"
	],
	"license": "MIT",
	"homepage": "https://github.com/your-org/n8n-nodes-quoter",
	"author": {
		"name": "Courant"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/your-org/n8n-nodes-quoter.git"
	},
	"main": "index.js",
	"scripts": {
		"build": "tsc && gulp build:icons",
		"dev": "tsc --watch",
		"format": "prettier nodes credentials --write",
		"lint": "eslint nodes credentials --ext .ts",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/QuoterApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Quoter/Quoter.node.js"
		]
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"gulp": "^4.0.2",
		"n8n-workflow": "^1.0.0",
		"typescript": "^5.3.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
